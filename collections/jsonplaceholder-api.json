  "info": {
    "_postman_id": "59799b4a-bb43-4541-8179-d129838ddf9c",
    "name": "JSONPlaceholder Blog API",
    "description": "A free, reliable fake REST API for prototyping and demos.\nServes ~3 billion requests per month. No auth required. No Cloudflare blocking.\nBase URL: https://jsonplaceholder.typicode.com\n\nResources:\n- 100 posts (blog articles with title, body, userId)\n- 500 comments (linked to posts)\n- 200 todos (tasks with completion status)\n- 10 users (with name, email, address, company)\n\nThis is a READ-ONLY demo API. POST/PUT/DELETE calls are faked —\nthey return success but nothing is actually saved to the database.\n",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "10675726"
  },
