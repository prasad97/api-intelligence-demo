  "item": [
    {
      "name": "Post count",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const body = pm.response.json();",
              "const answer = (body.message || body.response ||",
              "    body.content || JSON.stringify(body)).toLowerCase();",
              "",
              "pm.test(\"Mentions correct count — 100 posts\", () => {",
              "    pm.expect(answer).to.satisfy(a =>",
              "        a.includes(\"100\") || a.includes(\"one hundred\"),",
              "        \"Expected agent to say there are 100 posts\"",
              "    );",
              "});",
              "",
              "pm.test(\"Response within 5 seconds\", () => {",
              "    pm.expect(pm.response.responseTime).to.be.below(5000);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "protocolProfileBehavior": {
        "disableBodyPruning": true
      },
      "request": {
        "method": "GET",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_id\": \"eval-user\",\n  \"session_id\": \"{{session_id}}\",\n  \"message\": \"How many posts exist in total in this API?\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "response": []
    },
