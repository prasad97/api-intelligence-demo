              "const answer = (body.message || body.response ||",
              "    body.content || JSON.stringify(body)).toLowerCase();",
              "",
              "pm.test(\"Mentions posts\", () => {",
              "    pm.expect(answer).to.include(\"post\");",
              "});",
              "",
              "pm.test(\"Mentions users\", () => {",
              "    pm.expect(answer).to.include(\"user\");",
              "});",
              "",
              "pm.test(\"Mentions todos or tasks\", () => {",
              "    pm.expect(answer).to.satisfy(a =>",
              "        a.includes(\"todo\") || a.includes(\"task\"),",
              "        \"Expected agent to mention todos\"",
              "    );",
              "});",
              "",
              "pm.test(\"Does not invent fake resources\", () => {",
              "    pm.expect(answer).to.not.include(\"product\");",
              "    pm.expect(answer).to.not.include(\"order\");",
              "    pm.expect(answer).to.not.include(\"cart\");",
