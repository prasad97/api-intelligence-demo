    {
      "name": "Test coverage gaps",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const body = pm.response.json();",
              "const answer = (body.message || body.response ||",
              "    body.content || JSON.stringify(body)).toLowerCase();",
              "",
              "pm.test(\"Identifies POST /posts as untested\", () => {",
              "    pm.expect(answer).to.satisfy(a =>",
              "        a.includes(\"post\") && (a.includes(\"creat\") || a.includes(\"untested\") || a.includes(\"no test\") || a.includes(\"coverage\")),",
              "        \"Expected mention of POST /posts missing tests\"",
              "    );",
              "});",
              "",
              "pm.test(\"Identifies comments or todos as untested\", () => {",
              "    pm.expect(answer).to.satisfy(a =>",
              "        a.includes(\"comment\") || a.includes(\"todo\"),",
              "        \"Expected mention of comments or todos missing tests\"",
              "    );",
              "});"
            ],
