              "        \"Expected mention of missing authentication\"",
              "    );",
              "});",
              "",
              "pm.test(\"Mentions PII or sensitive data exposure\", () => {",
              "    pm.expect(answer).to.satisfy(a =>",
              "        a.includes(\"pii\") || a.includes(\"email\") ||",
              "        a.includes(\"sensitive\") || a.includes(\"personal\") ||",
              "        a.includes(\"privacy\") || a.includes(\"exposed\"),",
              "        \"Expected mention of PII/data exposure\"",
              "    );",
              "});",
              "",
              "pm.test(\"Response is substantive — more than 20 words\", () => {",
              "    const wordCount = answer.split(/\\s+/).length;",
              "    pm.expect(wordCount).to.be.greaterThan(20);",
